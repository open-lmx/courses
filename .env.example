# SurrealDB Configuration
SURREAL_URL=https://your-db.surrealdb.com
SURREAL_USER=root
SURREAL_PASS=your-password
SURREAL_NS=your-namespace
SURREAL_DB=your-database

# JWT Secret (generate a random string)
JWT_SECRET=your-secret-key-change-in-production

# OIDC/OAuth2 SSO Configuration
OIDC_PROVIDER_NAME=SSO
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=https://your-oidc-provider.com
OIDC_WELL_KNOWN=https://your-oidc-provider.com/.well-known/openid-configuration
OIDC_TOKEN_URL=https://your-oidc-provider.com/oauth/token
OIDC_USERINFO_URL=https://your-oidc-provider.com/oauth/userinfo

# Moodle Configuration
MOODLE_URL=https://your-moodle.com
MOODLE_TOKEN=your-moodle-web-service-token
